{% comment %}
  Bloco "Compre pelo WhatsApp" da página de produto.
  Parâmetros: product, block
{% endcomment %}
{% liquid
  assign block_st = block.settings
  assign show_button = block_st.enable_button

  assign selected_collections = block_st.collections
  assign matches_collection = true
  if selected_collections.size > 0
    assign matches_collection = false
    for selected_collection in selected_collections
      for product_collection in product.collections
        if product_collection.id == selected_collection.id
          assign matches_collection = true
          break
        endif
      endfor
      if matches_collection
        break
      endif
    endfor
  endif

  assign wa_number = block_st.whatsapp_number | remove: ' ' | remove: '+' | remove: '-' | remove: '(' | remove: ')' | remove: '.'
  assign wa_message = block_st.whatsapp_message | default: 'Olá! Tenho interesse neste produto:'
  assign button_text = block_st.button_text | default: 'Ou se preferir [whatsapp] <strong>COMPRE PELO WHATSAPP</strong>'

  assign product_url = request.origin | append: product.url
  if block_st.append_product_link
    assign wa_full_message = wa_message | append: ' ' | append: product_url
  else
    assign wa_full_message = wa_message
  endif
  assign wa_text = wa_full_message | url_encode

  if wa_number != blank
    assign wa_url = 'https://wa.me/' | append: wa_number | append: '?text=' | append: wa_text
  else
    assign wa_url = 'https://api.whatsapp.com/send?text=' | append: wa_text
  endif
%}

{% if show_button and matches_collection %}
  {%- capture wa_icon -%}
    <span class="whatsapp-cta__icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M13.601 2.326A7.85 7.85 0 0 0 7.994 0C3.627 0 .068 3.558.064 7.926c0 1.399.366 2.76 1.057 3.965L0 16l4.204-1.102a7.9 7.9 0 0 0 3.79.965h.004c4.368 0 7.926-3.558 7.93-7.93A7.9 7.9 0 0 0 13.6 2.326zM7.994 14.521a6.6 6.6 0 0 1-3.356-.92l-.24-.144-2.494.654.666-2.433-.156-.251a6.56 6.56 0 0 1-1.007-3.505c0-3.626 2.957-6.584 6.591-6.584a6.56 6.56 0 0 1 4.66 1.931 6.56 6.56 0 0 1 1.928 4.66c-.004 3.639-2.961 6.592-6.592 6.592m3.615-4.934c-.197-.099-1.17-.578-1.353-.646-.182-.065-.315-.099-.445.099-.133.197-.513.646-.627.775-.114.133-.232.148-.43.05-.197-.1-.836-.308-1.592-.985-.59-.525-.985-1.175-1.103-1.372-.114-.198-.011-.304.088-.403.087-.088.197-.232.296-.346.1-.114.133-.198.198-.33.065-.134.034-.248-.015-.347-.05-.099-.445-1.076-.612-1.47-.16-.389-.323-.335-.445-.34-.114-.007-.247-.007-.38-.007a.73.73 0 0 0-.529.247c-.182.198-.691.677-.691 1.654s.71 1.916.81 2.049c.098.133 1.394 2.132 3.383 2.992.47.205.84.326 1.129.418.475.152.904.129 1.246.08.38-.058 1.171-.48 1.338-.943.164-.464.164-.86.114-.943-.049-.084-.182-.133-.38-.232"/></svg></span>
  {%- endcapture -%}
  {%- assign rendered_text = button_text | replace: '[whatsapp]', wa_icon -%}

  <style>
    .product-detail__whatsapp-cta { text-align: center; }
    .whatsapp-cta {
      color: var(--wa-color, #128c4a);
      line-height: 1.5;
      text-decoration: none;
    }
    .whatsapp-cta:hover { text-decoration: none; opacity: .85; }
    .whatsapp-cta__icon { display: inline-block; vertical-align: middle; line-height: 0; margin: 0 5px; }
    .whatsapp-cta__icon svg {
      width: 1.5em; height: 1.5em;
      background: #25d366;
      border-radius: 50%;
      padding: 3px;
      fill: #fff;
      vertical-align: middle;
    }
  </style>

  <div class="product-detail__whatsapp-cta mb-20" style="--wa-color: {{ block_st.text_color | default: '#128c4a' }};" {{ block.shopify_attributes }}>
    <a
      href="{{ wa_url }}"
      target="_blank"
      rel="noopener"
      class="whatsapp-cta"
    >{{ rendered_text }}</a>
  </div>
{% endif %}
